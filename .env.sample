# eBot server configuration
EBOT_IP=127.0.0.1
EBOT_WEBSOCKET_URL=http://127.0.0.1:12360
EBOT_WEBSOCKET_SECRET_KEY=strongpassword

# Log receiver address (must be reachable from CS2 game servers, UDP port 12345)
LOG_ADDRESS_SERVER=udp://127.0.0.1:12345

# eBot admin account (created on first run)
EBOT_ADMIN_LOGIN=admin
EBOT_ADMIN_PASSWORD=admin
EBOT_ADMIN_EMAIL=admin@admin

# eBot Socket settings
COMMAND_STOP_DISABLED=true

# Database configuration
MYSQL_USER=ebotv3
MYSQL_DATABASE=ebotv3
MYSQL_PASSWORD=strongpassword
MYSQL_ROOT_PASSWORD=strongpassword

# Display settings (net=hide server IPs, lan=show them)
EBOT_MODE=net
EBOT_DEMO_DOWNLOAD=true
EBOT_REFRESH_TIME=30
